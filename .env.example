# Backend selection: json | sqlite | postgres | influx
DATA_BACKEND=json
HISTORY_LIMIT=120

# SQLite
SQLITE_PATH=storage/metrics.sqlite

# Postgres
PG_URL=postgres://postgres:postgres@localhost:5432/projet_e6
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=projet_e6

# InfluxDB
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-token-here
INFLUX_ORG=projet-e6
INFLUX_BUCKET=aquaculture
INFLUX_RANGE=-30d
INFLUX_RETENTION=30d

# Strict mode (fail if backend init fails)
DATA_STRICT=0

# Admin access
ADMIN_USER=admin
ADMIN_PASS=admin123

# MQTT (Mosquitto)
MQTT_ENABLED=1
MQTT_URL=mqtt://localhost:1883
MQTT_TOPIC=tp/esp32/telemetry
MQTT_COMMAND_TOPIC=tp/esp32/cmd
MQTT_STATE_TOPIC=tp/esp32/state
MQTT_CLIENT_ID=projet-e6-server
MQTT_DEVICE_TIMEOUT_MS=30000

# Alert email (optional)
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
SMTP_URL=
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
